# LLM (MiMo via OpenAI-compatible API)
NEXT_PUBLIC_LLM_API_BASE=https://token-plan-sgp.xiaomimimo.com/v1
NEXT_PUBLIC_LLM_API_KEY=your-api-key
NEXT_PUBLIC_LLM_MODEL=mimo-v2.5-pro

# Embeddings (Ollama)
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Google Drive
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/auth/callback
DRIVE_FOLDER_ID=your-target-folder-id

# App
DATA_DIR=./data
